```gitignore
########################################
# General
########################################
.DS_Store
Thumbs.db
*.log

########################################
# Spring Boot / Maven
########################################
HELP.md
target/
.mvn/wrapper/maven-wrapper.jar

!**/src/main/**/target/
!**/src/test/**/target/

########################################
# Java
########################################
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

########################################
# IntelliJ IDEA
########################################
.idea/
*.iml
*.iws
*.ipr
out/

########################################
# Eclipse / STS
########################################
.project
.classpath
.settings/
.factorypath
.springBeans
.sts4-cache
.apt_generated

########################################
# VS Code
########################################
.vscode/

########################################
# NetBeans
########################################
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

!**/src/main/**/build/
!**/src/test/**/build/

########################################
# React / Node.js
########################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

########################################
# Build Outputs
########################################
dist/
build/
coverage/
.vite/
.cache/

########################################
# Environment Files
########################################
.env
.env.*
!.env.example

########################################
# Package Managers
########################################
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

########################################
# TypeScript
########################################
*.tsbuildinfo

########################################
# Misc
########################################
*.swp
*.swo
```
